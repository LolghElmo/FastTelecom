<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FastTelecom.AvaloniaUI.ViewModels"
             x:Class="FastTelecom.AvaloniaUI.Views.BundlesView"
             x:DataType="vm:BundlesViewModel">
    <Grid RowDefinitions="Auto,*">
        <StackPanel Grid.Row="0" Spacing="0">
            <Border Padding="32,12"
                    Background="{StaticResource SuccessBrush}"
                    IsVisible="{Binding StatusMessage,
                        Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="White" FontWeight="Medium" FontSize="13" />
            </Border>
            <Border Padding="32,12"
                    Background="{StaticResource DangerBrush}"
                    IsVisible="{Binding ErrorMessage,
                        Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="White" FontWeight="Medium" FontSize="13"
                           TextWrapping="Wrap" />
            </Border>
            <Border Padding="32,12"
                    Background="{StaticResource AccentBrush}"
                    IsVisible="{Binding IsPurchasing}">
                <TextBlock Text="Processing your purchase, please wait…"
                           Foreground="White" FontWeight="Medium" FontSize="13" />
            </Border>
        </StackPanel>
        <ScrollViewer Grid.Row="1" Padding="24,20,24,0"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="BundlesList" ItemsSource="{Binding Bundles}"
                          Margin="0,0,0,40">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3" Margin="0,0,-16,0" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:CompileBindings="False">
                        <Border Classes="bundle-card" Margin="0,0,16,16">
                            <StackPanel Spacing="13">
                                <TextBlock Text="{Binding VolGb, StringFormat='{}{0} GB'}"
                                           FontSize="30" FontWeight="ExtraBold"
                                           Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding Name}"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           HorizontalAlignment="Center" />
                                <Border Background="{StaticResource SurfaceBrush}"
                                        CornerRadius="8"
                                        Padding="10,7">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                Spacing="6">
                                        <TextBlock Text="{Binding Price, StringFormat='{}{0:N0}'}"
                                                   FontSize="17" FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center" />
                                        <Border Background="#EFF6FF"
                                                CornerRadius="4"
                                                Padding="5,2"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="SP"
                                                       FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{StaticResource AccentBrush}" />
                                        </Border>
                                    </StackPanel>
                                </Border>
                                <Button Classes="buy-btn"
                                        Content="Buy"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        Command="{Binding #BundlesList.DataContext.PurchaseCommand}"
                                        CommandParameter="{Binding}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        <TextBlock Grid.Row="1"
                   IsVisible="{Binding ShowEmptyState}"
                   Text="No bundles available."
                   FontSize="15"
                   Foreground="{StaticResource TextMutedBrush}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
    </Grid>
    <UserControl.Styles>
        <Style Selector="Border.bundle-card">
            <Setter Property="Background"      Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius"    Value="16" />
            <Setter Property="Padding"         Value="18,16" />
            <Setter Property="BoxShadow"       Value="0 2 8 0 #10000000" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" />
                    <BoxShadowsTransition          Property="BoxShadow"       Duration="0:0:0.15" />
                    <BrushTransition               Property="BorderBrush"     Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.bundle-card:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.025)" />
            <Setter Property="BoxShadow" Value="0 8 28 0 #252563EB, 0 2 8 0 #10000000" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        </Style>
        <Style Selector="Button.buy-btn">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="0,9" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.buy-btn /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.12" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.buy-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource AccentHoverBrush}" />
        </Style>
        <Style Selector="Button.buy-btn:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource BorderBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
        </Style>
    </UserControl.Styles>
</UserControl>
