<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FastTelecom.AvaloniaUI.ViewModels"
             xmlns:conv="using:FastTelecom.AvaloniaUI.Converters"
             x:Class="FastTelecom.AvaloniaUI.Views.ActiveBundlesView"
             x:DataType="vm:ActiveBundlesViewModel">
    <Grid>
        <ScrollViewer>
            <StackPanel Margin="32,24,32,24" Spacing="0" >
                <Border IsVisible="{Binding HasPinnedBundle}"
                        x:CompileBindings="False"
                        CornerRadius="14"
                        Margin="0,0,0,8"
                        Padding="24,20"
                        ClipToBounds="True">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                            <GradientStop Color="#1E40AF" Offset="0" />
                            <GradientStop Color="#2563EB" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel Spacing="14">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border CornerRadius="20" Padding="10,4" Background="#33FFFFFF">
                                <TextBlock Text="● LIVE NOW"
                                           FontSize="11" FontWeight="Bold" Foreground="White" />
                            </Border>
                            <TextBlock Text="Currently Active"
                                       FontSize="11" Foreground="White" Opacity="0.7"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding PinnedBundle.TotalDisplay}"
                                       FontSize="26" FontWeight="Bold"
                                       Foreground="White" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding PinnedBundle.Name}"
                                       FontSize="17" FontWeight="SemiBold"
                                       Foreground="White" VerticalAlignment="Center"
                                       TextWrapping="Wrap" />
                        </DockPanel>
                        <StackPanel IsVisible="{Binding PinnedBundle.IsVolumeBundle}" Spacing="8">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding PinnedBundle.PercentLabel}"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="White" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding PinnedBundle.UsedOfTotalDisplay}"
                                           FontSize="13" Foreground="White" Opacity="0.85"
                                           VerticalAlignment="Center" />
                            </DockPanel>
                            <ProgressBar Value="{Binding PinnedBundle.PercentUsed}"
                                         Maximum="100" MinHeight="10" CornerRadius="5"
                                         Background="#33FFFFFF" Foreground="White">
                                <ProgressBar.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="Value" Duration="0:0:1" Easing="CubicEaseOut" />
                                    </Transitions>
                                </ProgressBar.Transitions>
                            </ProgressBar>
                        </StackPanel>
                        <StackPanel IsVisible="{Binding PinnedBundle.IsUnlimited}" Spacing="4">
                            <TextBlock Text="Unlimited Data"
                                       FontSize="15" FontWeight="SemiBold" Foreground="White" />
                            <TextBlock Text="{Binding PinnedBundle.MonthlyUsedDisplay}"
                                       FontSize="13" Foreground="White" Opacity="0.8" />
                        </StackPanel>
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding PinnedBundle.ExpiryDate, StringFormat='Expires {0}'}"
                                       FontSize="12" Foreground="White" Opacity="0.65"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding PinnedBundle.Speed, StringFormat='⚡ {0}'}"
                                       FontSize="12" Foreground="White" Opacity="0.65"
                                       VerticalAlignment="Center" />
                        </DockPanel>
                    </StackPanel>
                </Border>
                <TextBlock Text="ALL ACTIVE BUNDLES"
                           FontSize="11" FontWeight="Bold" LetterSpacing="1.5"
                           Foreground="{StaticResource TextMutedBrush}"
                           Margin="2,16,0,12" />
                <ItemsControl ItemsSource="{Binding Bundles}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:CompileBindings="False">
                            <Border Classes="active-card" Margin="0,0,0,12">
                                <StackPanel Spacing="12">
                                    <DockPanel>
                                        <Border IsVisible="{Binding IsOnline}"
                                                DockPanel.Dock="Right"
                                                Classes="online-badge"
                                                VerticalAlignment="Top">
                                            <TextBlock Text="● LIVE" FontSize="11"
                                                       FontWeight="Bold" Foreground="White" />
                                        </Border>
                                        <Border IsVisible="{Binding IsExpiringSoon}"
                                                DockPanel.Dock="Right"
                                                Classes="expiring-badge"
                                                VerticalAlignment="Top" Margin="0,0,8,0">
                                            <TextBlock Text="⚠ EXPIRING SOON" FontSize="11"
                                                       FontWeight="Bold" Foreground="White" />
                                        </Border>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="15" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                            <TextBlock Text="{Binding TotalDisplay}"
                                                       FontSize="12" FontWeight="Medium"
                                                       Foreground="{StaticResource AccentBrush}" />
                                        </StackPanel>
                                    </DockPanel>
                                    <Border Height="1" Background="{StaticResource BorderBrush}" />
                                    <StackPanel IsVisible="{Binding IsVolumeBundle}" Spacing="6">
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Right"
                                                       Text="{Binding PercentLabel}"
                                                       FontSize="14" FontWeight="Bold"
                                                       VerticalAlignment="Center"
                                                       Foreground="{Binding PercentUsed,
                                                           Converter={x:Static conv:PercentToBrushConverter.Instance}}" />
                                            <TextBlock Text="{Binding UsedOfTotalDisplay}"
                                                       FontSize="12" VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                        </DockPanel>
                                        <ProgressBar Value="{Binding PercentUsed}"
                                                     Maximum="100" MinHeight="12" CornerRadius="6"
                                                     Background="{StaticResource BorderBrush}"
                                                     Foreground="{Binding PercentUsed,
                                                         Converter={x:Static conv:PercentToBrushConverter.Instance}}">
                                            <ProgressBar.Transitions>
                                                <Transitions>
                                                    <DoubleTransition Property="Value" Duration="0:0:1" Easing="CubicEaseOut" />
                                                </Transitions>
                                            </ProgressBar.Transitions>
                                        </ProgressBar>
                                    </StackPanel>
                                    <StackPanel IsVisible="{Binding IsUnlimited}" Spacing="4">
                                        <Border CornerRadius="8" Padding="14,8"
                                                Background="{StaticResource SurfaceBrush}">
                                            <DockPanel>
                                                <TextBlock DockPanel.Dock="Right"
                                                           Text="∞" FontSize="20" FontWeight="Bold"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           VerticalAlignment="Center" />
                                                <StackPanel Spacing="2" VerticalAlignment="Center">
                                                    <TextBlock Text="Unlimited Data"
                                                               FontWeight="SemiBold" FontSize="13"
                                                               Foreground="{StaticResource AccentBrush}" />
                                                    <TextBlock Text="{Binding MonthlyUsedDisplay}"
                                                               FontSize="12"
                                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </StackPanel>
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="{Binding ExpiryDate, StringFormat='Expires {0}'}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Speed, StringFormat='⚡ {0}'}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   VerticalAlignment="Center" />
                                    </DockPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
        <TextBlock IsVisible="{Binding ShowEmptyState}"
                   Text="No active bundles found."
                   FontSize="15"
                   Foreground="{StaticResource TextMutedBrush}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
    </Grid>
    <UserControl.Styles>
        <Style Selector="Border.active-card">
            <Setter Property="Background"      Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius"    Value="12" />
            <Setter Property="Padding"         Value="20,16" />
            <Setter Property="Transitions">
                <Transitions>
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.active-card:pointerover">
            <Setter Property="BoxShadow" Value="0 2 16 0 #15000000" />
        </Style>
        <Style Selector="Border.online-badge">
            <Setter Property="Background"   Value="#16A34A" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding"      Value="10,4" />
        </Style>
        <Style Selector="Border.expiring-badge">
            <Setter Property="Background"   Value="#D97706" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding"      Value="10,4" />
        </Style>
        <Style Selector="ProgressBar /template/ Border#PART_Indicator">
            <Setter Property="CornerRadius" Value="6" />
        </Style>
    </UserControl.Styles>
</UserControl>
