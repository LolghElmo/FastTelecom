<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FastTelecom.AvaloniaUI.ViewModels"
             x:Class="FastTelecom.AvaloniaUI.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">
    <ScrollViewer Padding="32,24,32,0" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="0" Margin="0,0,0,40">
            <Border Classes="account-card" Margin="0,0,0,28">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center">
                        <Border CornerRadius="20" Padding="16,7"
                                Background="{StaticResource SuccessBrush}"
                                IsVisible="{Binding IsActive}">
                            <TextBlock Text="● Active"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="White" />
                        </Border>
                        <Border CornerRadius="20" Padding="16,7"
                                Background="{StaticResource DangerBrush}"
                                IsVisible="{Binding !IsActive}">
                            <TextBlock Text="✕ Inactive"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="White" />
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding SubscriberId}"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center" />
                </DockPanel>
            </Border>
            <TextBlock Classes="section-header" Text="SUBSCRIPTION VALIDITY"
                       Margin="0,0,0,12" />
            <Grid ColumnDefinitions="*,14,*" Margin="0,0,0,28">
                <Border Grid.Column="0" Classes="date-card">
                    <StackPanel Spacing="14">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Classes="icon-pill">
                                <TextBlock Text="◷" Classes="icon-glyph" />
                            </Border>
                            <TextBlock Text="Effective From" Classes="card-label"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{Binding EffectTime}" Classes="date-value" />
                        <TextBlock Text="Subscription start date"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Classes="date-card">
                    <StackPanel Spacing="14">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Classes="icon-pill">
                                <TextBlock Text="◷" Classes="icon-glyph" />
                            </Border>
                            <TextBlock Text="Expires" Classes="card-label"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{Binding ExpireTime}" Classes="date-value" />
                        <TextBlock Text="Subscription end date"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}" />
                    </StackPanel>
                </Border>
            </Grid>
            <TextBlock Classes="section-header" Text="USAGE HISTORY"
                       Margin="0,0,0,12" />
            <Grid ColumnDefinitions="*,14,*">
                <Border Grid.Column="0" Classes="date-card">
                    <StackPanel Spacing="14">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Classes="icon-pill icon-pill-green">
                                <TextBlock Text="⊙" Classes="icon-glyph icon-glyph-green" />
                            </Border>
                            <TextBlock Text="First Used" Classes="card-label"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{Binding FirstUseTime}" Classes="date-value" />
                        <TextBlock Text="Account activation date"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Classes="date-card">
                    <StackPanel Spacing="14">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Classes="icon-pill icon-pill-green">
                                <TextBlock Text="⊙" Classes="icon-glyph icon-glyph-green" />
                            </Border>
                            <TextBlock Text="Last Used" Classes="card-label"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <TextBlock Text="{Binding LastUseEndTime}" Classes="date-value" />
                            <Border Classes="relative-badge">
                                <TextBlock Text="{Binding LastUseRelative}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="#16A34A" />
                            </Border>
                        </StackPanel>
                        <TextBlock Text="Most recent session"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}" />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
    <UserControl.Styles>
        <Style Selector="Border.account-card">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="24,18" />
            <Setter Property="BoxShadow" Value="0 1 8 0 #0C000000" />
        </Style>
        <Style Selector="TextBlock.section-header">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="LetterSpacing" Value="1.5" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
        </Style>
        <Style Selector="Border.date-card">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="22,18" />
            <Setter Property="BoxShadow" Value="0 1 6 0 #0A000000" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15"
                                                   Easing="CubicEaseOut" />
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.15" />
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.date-card:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.012)" />
            <Setter Property="BoxShadow" Value="0 6 24 0 #1A2563EB, 0 2 8 0 #10000000" />
            <Setter Property="BorderBrush"     
                    Value="{StaticResource AccentBrush}" />
        </Style>
        <Style Selector="Border.icon-pill">
            <Setter Property="Background"   
                    Value="#EFF6FF" />
            <Setter Property="CornerRadius"
                    Value="8" />
            <Setter Property="Width"       
                    Value="32" />
            <Setter Property="Height"    
                    Value="32" />
        </Style>
        <Style Selector="Border.icon-pill-green">
            <Setter Property="Background" Value="#F0FDF4" />
        </Style>
        <Style Selector="TextBlock.icon-glyph">
            <Setter Property="FontSize"           
                    Value="15" />
            <Setter Property="FontWeight"      
                    Value="Bold" />
            <Setter Property="Foreground"     
                    Value="{StaticResource AccentBrush}" />
            <Setter Property="HorizontalAlignment"
                    Value="Center" />
            <Setter Property="VerticalAlignment" 
                    Value="Center" />
        </Style>
        <Style Selector="TextBlock.icon-glyph-green">
            <Setter Property="Foreground" Value="#16A34A" />
        </Style>
        <Style Selector="TextBlock.card-label">
            <Setter Property="FontSize"  
                    Value="12" />
            <Setter Property="Foreground"
                    Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontWeight"
                    Value="Medium" />
        </Style>
        <Style Selector="TextBlock.date-value">
            <Setter Property="FontSize"  
                    Value="21" />
            <Setter Property="FontWeight" 
                    Value="Bold" />
            <Setter Property="Foreground"
                    Value="{StaticResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="Border.relative-badge">
            <Setter Property="Background"     
                    Value="#F0FDF4" />
            <Setter Property="BorderBrush"    
                    Value="#BBF7D0" />
            <Setter Property="BorderThickness" 
                    Value="1" />
            <Setter Property="CornerRadius"   
                    Value="10" />
            <Setter Property="Padding"        
                    Value="10,4" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
    </UserControl.Styles>
</UserControl>
