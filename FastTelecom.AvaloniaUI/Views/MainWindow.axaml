<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FastTelecom.AvaloniaUI.ViewModels"
        x:Class="FastTelecom.AvaloniaUI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding AppVersion, StringFormat='FastTelecom {0}'}"
        Icon="avares://FastTelecom/Assets/icon-256.png"
        Width="960" Height="640"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SurfaceBrush}">
    <Panel>
        <Border Classes.content-dimmed="{Binding IsOverlayVisible}">
            <Border.Transitions>
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.25" Easing="CubicEaseOut" />
                </Transitions>
            </Border.Transitions>
            <DockPanel>
                <Border DockPanel.Dock="Left"
                        Width="220"
                        Background="{StaticResource SidebarBrush}"
                        IsVisible="{Binding ShowShell}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Padding="20,24,20,20">
                            <StackPanel Spacing="2">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="FastTelecom"
                                               FontSize="18" FontWeight="SemiBold"
                                               Foreground="White" />
                                    <Ellipse Width="8" Height="8"
                                             Fill="#34D399"
                                             VerticalAlignment="Center"
                                             IsVisible="{Binding Update.IsUpdateAvailable}"
                                             ToolTip.Tip="Update available" />
                                </StackPanel>
                                <TextBlock Text="{Binding AppVersion, StringFormat='v{0}'}"
                                           FontSize="11"
                                           Foreground="{StaticResource SidebarTextBrush}" />
                            </StackPanel>
                        </Border>
                        <StackPanel DockPanel.Dock="Top" Spacing="2" Margin="8,8,8,0">
                            <Button Command="{Binding NavigateToDashboardCommand}"
                                    Classes="nav-item"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="&#x2302;" FontSize="16"
                                               Foreground="{StaticResource SidebarTextBrush}" />
                                    <TextBlock Text="Dashboard"
                                               Foreground="{StaticResource SidebarTextBrush}" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding NavigateToBundlesCommand}"
                                    Classes="nav-item"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="&#x229E;" FontSize="16"
                                               Foreground="{StaticResource SidebarTextBrush}" />
                                    <TextBlock Text="Bundles"
                                               Foreground="{StaticResource SidebarTextBrush}" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding NavigateToActiveBundlesCommand}"
                                    Classes="nav-item"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="&#x25A6;" FontSize="16"
                                               Foreground="{StaticResource SidebarTextBrush}" />
                                    <TextBlock Text="My Bundles"
                                               Foreground="{StaticResource SidebarTextBrush}" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        <!-- Update available button — only visible when update is found -->
                        <Border DockPanel.Dock="Bottom"
                                Padding="8,0,8,8"
                                IsVisible="{Binding Update.IsUpdateAvailable}">
                            <Button Classes="update-sidebar-btn"
                                    Command="{Binding Update.ShowPromptCommand}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Padding="10,9"
                                    CornerRadius="8"
                                    Cursor="Hand">
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                    <Ellipse Width="7" Height="7"
                                             Fill="White"
                                             VerticalAlignment="Center"
                                             Opacity="0.9" />
                                    <TextBlock Text="Update available"
                                               Foreground="White"
                                               FontSize="12.5"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                        </Border>

                        <Border DockPanel.Dock="Bottom" Padding="8,0,8,16">
                            <Button Command="{Binding LogoutCommand}"
                                    Classes="nav-item"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="&#x2190;" FontSize="16"
                                               Foreground="{StaticResource SidebarTextBrush}" />
                                    <TextBlock Text="Logout"
                                               Foreground="{StaticResource SidebarTextBrush}" />
                                </StackPanel>
                            </Button>
                        </Border>
                        <Border />
                    </DockPanel>
                </Border>
                <Border>
                    <DockPanel>
                        <Border DockPanel.Dock="Top"
                                Padding="32,20,32,16"
                                IsVisible="{Binding ShowShell}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <TextBlock Text="{Binding CurrentPageTitle}"
                                       FontSize="20" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </Border>
                        <TransitioningContentControl Content="{Binding CurrentView}"
                                                     VerticalContentAlignment="Stretch"
                                                     HorizontalContentAlignment="Stretch">
                            <TransitioningContentControl.PageTransition>
                                <CrossFade Duration="0:0:0.18" />
                            </TransitioningContentControl.PageTransition>
                        </TransitioningContentControl>
                    </DockPanel>
                </Border>
            </DockPanel>
        </Border>
        <Panel IsVisible="{Binding IsPageLoading}"
               Classes="overlay-panel"
               Background="#B80F172A">
            <Border Classes="overlay-card"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel Spacing="22" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                        <Ellipse Classes="dot-1" Width="13" Height="13" />
                        <Ellipse Classes="dot-2" Width="13" Height="13" />
                        <Ellipse Classes="dot-3" Width="13" Height="13" />
                    </StackPanel>
                    <TextBlock Text="{Binding PageLoadingMessage}"
                               FontSize="13" FontWeight="Medium"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               MaxWidth="260" />
                </StackPanel>
            </Border>
        </Panel>
        <Panel IsVisible="{Binding IsPageFailed}"
               Classes="overlay-panel"
               Background="#B80F172A">
            <Border Classes="overlay-card"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel Spacing="14" HorizontalAlignment="Center">
                    <TextBlock Text="⚠" FontSize="36" HorizontalAlignment="Center" />
                    <TextBlock Text="Connection failed"
                               FontSize="17" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               MaxWidth="280"
                               TextWrapping="Wrap">
                        The server didn't respond after 5 attempts. This could be a
                        temporary outage or a network issue on your end — please check
                        your connection and try again.
                    </TextBlock>
                    <Button Classes="overlay-retry"
                            Content="Try again"
                            HorizontalAlignment="Center"
                            Margin="0,8,0,0"
                            Command="{Binding RetryPageCommand}" />
                </StackPanel>
            </Border>
        </Panel>
        <Panel IsVisible="{Binding Update.ShowUpdatePrompt}"
               Classes="overlay-panel"
               Background="#B80F172A">
            <Border Classes="overlay-card"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxWidth="380">
                <StackPanel Spacing="16" HorizontalAlignment="Center">
                    <Border Background="#EFF6FF"
                            CornerRadius="24"
                            Width="52" Height="52"
                            HorizontalAlignment="Center">
                        <TextBlock Text="&#x2191;"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Update available"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" />
                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                        <TextBlock FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap">
                            A new version is ready to install. The application
                            will restart automatically after updating.
                        </TextBlock>
                        <TextBlock Text="{Binding Update.AvailableVersion, StringFormat='Version {0}'}"
                                   FontSize="12" FontWeight="Medium"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                    <StackPanel Spacing="8" Margin="0,4,0,0">
                        <Button Command="{Binding Update.ApplyUpdateCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Padding="0,11"
                                CornerRadius="8"
                                FontWeight="Medium"
                                FontSize="13"
                                Cursor="Hand"
                                Classes="update-primary">
                            <Panel>
                                <TextBlock Text="Update now"
                                           IsVisible="{Binding !Update.IsApplyingUpdate}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Installing..."
                                           IsVisible="{Binding Update.IsApplyingUpdate}"
                                           HorizontalAlignment="Center" />
                            </Panel>
                        </Button>
                        <Button Command="{Binding Update.DismissUpdateCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Padding="0,11"
                                CornerRadius="8"
                                FontWeight="Medium"
                                FontSize="13"
                                Cursor="Hand"
                                Classes="update-secondary">
                            <TextBlock Text="Not now" HorizontalAlignment="Center" />
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Panel>
    </Panel>
    <Window.Styles>
        <Style Selector="Border.content-dimmed">
            <Setter Property="Opacity" Value="0.35" />
        </Style>
        <Style Selector="Panel.overlay-panel">
            <Style.Animations>
                <Animation Duration="0:0:0.22" FillMode="Forward">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="1" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Button.nav-item">
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius"    Value="8" />
            <Setter Property="Padding"         Value="12,10" />
            <Setter Property="Cursor"          Value="Hand" />
        </Style>
        <Style Selector="Button.nav-item /template/ ContentPresenter">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.12" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.nav-item:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}" />
        </Style>
        <Style Selector="Button.update-primary /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.12" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.update-primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource AccentHoverBrush}" />
        </Style>
        <Style Selector="Button.update-secondary">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Button.update-secondary /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.12" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.update-secondary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource BorderBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="Button.update-sidebar-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Button.update-sidebar-btn /template/ ContentPresenter">
            <Setter Property="Background" Value="#16A34A" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.12" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.update-sidebar-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#15803D" />
        </Style>
    </Window.Styles>
</Window>
