<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FastTelecom.AvaloniaUI.ViewModels"
        x:Class="FastTelecom.AvaloniaUI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding AppVersion, StringFormat='FastTelecom {0}'}"
        Icon="avares://FastTelecom.AvaloniaUI/Assets/icon-256.png"
        Width="960" Height="640"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SurfaceBrush}">
    <Panel>
        <Border Classes.content-dimmed="{Binding IsOverlayVisible}">
            <Border.Transitions>
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.25" Easing="CubicEaseOut" />
                </Transitions>
            </Border.Transitions>
            <DockPanel>
                <Border DockPanel.Dock="Left"
                        Width="220"
                        Background="{StaticResource SidebarBrush}"
                        IsVisible="{Binding ShowShell}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Padding="20,24,20,20">
                            <StackPanel Spacing="2">
                                <TextBlock Text="FastTelecom"
                                           FontSize="18" FontWeight="SemiBold"
                                           Foreground="White" />
                                <TextBlock Text="{Binding AppVersion, StringFormat='v{0}'}"
                                           FontSize="11"
                                           Foreground="{StaticResource SidebarTextBrush}" />
                            </StackPanel>
                        </Border>
                        <StackPanel DockPanel.Dock="Top" Spacing="2" Margin="8,8,8,0">
                            <Button Command="{Binding NavigateToDashboardCommand}"
                                    Classes="nav-item"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="&#x2302;" FontSize="16"
                                               Foreground="{StaticResource SidebarTextBrush}" />
                                    <TextBlock Text="Dashboard"
                                               Foreground="{StaticResource SidebarTextBrush}" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding NavigateToBundlesCommand}"
                                    Classes="nav-item"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="&#x229E;" FontSize="16"
                                               Foreground="{StaticResource SidebarTextBrush}" />
                                    <TextBlock Text="Bundles"
                                               Foreground="{StaticResource SidebarTextBrush}" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding NavigateToActiveBundlesCommand}"
                                    Classes="nav-item"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="&#x25A6;" FontSize="16"
                                               Foreground="{StaticResource SidebarTextBrush}" />
                                    <TextBlock Text="My Bundles"
                                               Foreground="{StaticResource SidebarTextBrush}" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        <Border DockPanel.Dock="Bottom" Padding="8,0,8,8">
                            <StackPanel Spacing="4">
                                <Border IsVisible="{Binding Update.IsUpdateAvailable}"
                                        Background="#1E3A5F"
                                        CornerRadius="8"
                                        Padding="12,10">
                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="↑"
                                                       Foreground="#60A5FA"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="Update available"
                                                       Foreground="White"
                                                       FontSize="12"
                                                       FontWeight="SemiBold" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding Update.AvailableVersion, StringFormat='v{0}'}"
                                                   Foreground="#93C5FD"
                                                   FontSize="11" />
                                        <Button Command="{Binding Update.ApplyUpdateCommand}"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center"
                                                Padding="0,7"
                                                CornerRadius="6"
                                                Background="#2563EB"
                                                Foreground="White"
                                                FontSize="12"
                                                FontWeight="Medium"
                                                Cursor="Hand">
                                            <Panel>
                                                <TextBlock Text="Install &amp; restart"
                                                           IsVisible="{Binding !Update.IsApplyingUpdate}"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock Text="Installing..."
                                                           IsVisible="{Binding Update.IsApplyingUpdate}"
                                                           HorizontalAlignment="Center" />
                                            </Panel>
                                        </Button>
                                    </StackPanel>
                                </Border>
                                <Button Command="{Binding Update.CheckForUpdatesCommand}"
                                        Classes="nav-item"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="&#x27F3;"
                                                   FontSize="15"
                                                   Foreground="{StaticResource SidebarTextBrush}" />
                                        <Panel>
                                            <TextBlock Text="Check for updates"
                                                       IsVisible="{Binding !Update.IsCheckingForUpdates}"
                                                       Foreground="{StaticResource SidebarTextBrush}"
                                                       FontSize="13" />
                                            <TextBlock Text="Checking..."
                                                       IsVisible="{Binding Update.IsCheckingForUpdates}"
                                                       Foreground="{StaticResource SidebarTextBrush}"
                                                       FontSize="13" />
                                        </Panel>
                                    </StackPanel>
                                </Button>

                            </StackPanel>
                        </Border>

                        <Border DockPanel.Dock="Bottom" Padding="8,0,8,16">
                            <Button Command="{Binding LogoutCommand}"
                                    Classes="nav-item"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="&#x2190;" FontSize="16"
                                               Foreground="{StaticResource SidebarTextBrush}" />
                                    <TextBlock Text="Logout"
                                               Foreground="{StaticResource SidebarTextBrush}" />
                                </StackPanel>
                            </Button>
                        </Border>
                        <Border />
                    </DockPanel>
                </Border>
                <Border>
                    <DockPanel>
                        <Border DockPanel.Dock="Top"
                                Padding="32,20,32,16"
                                IsVisible="{Binding ShowShell}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <TextBlock Text="{Binding CurrentPageTitle}"
                                       FontSize="20" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </Border>
                        <TransitioningContentControl Content="{Binding CurrentView}"
                                                     VerticalContentAlignment="Stretch"
                                                     HorizontalContentAlignment="Stretch">
                            <TransitioningContentControl.PageTransition>
                                <CrossFade Duration="0:0:0.18" />
                            </TransitioningContentControl.PageTransition>
                        </TransitioningContentControl>
                    </DockPanel>
                </Border>
            </DockPanel>
        </Border>
        <Panel IsVisible="{Binding IsPageLoading}"
               Classes="overlay-panel"
               Background="#B80F172A">
            <Border Classes="overlay-card"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel Spacing="22" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                        <Ellipse Classes="dot-1" Width="13" Height="13" />
                        <Ellipse Classes="dot-2" Width="13" Height="13" />
                        <Ellipse Classes="dot-3" Width="13" Height="13" />
                    </StackPanel>
                    <TextBlock Text="{Binding PageLoadingMessage}"
                               FontSize="13" FontWeight="Medium"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               MaxWidth="260" />
                </StackPanel>
            </Border>
        </Panel>
        <Panel IsVisible="{Binding IsPageFailed}"
               Classes="overlay-panel"
               Background="#B80F172A">
            <Border Classes="overlay-card"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel Spacing="14" HorizontalAlignment="Center">
                    <TextBlock Text="⚠" FontSize="36" HorizontalAlignment="Center" />
                    <TextBlock Text="Connection failed"
                               FontSize="17" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               MaxWidth="280"
                               TextWrapping="Wrap">
                        The server didn't respond after 5 attempts. This could be a
                        temporary outage or a network issue on your end — please check
                        your connection and try again.
                    </TextBlock>
                    <Button Classes="overlay-retry"
                            Content="Try again"
                            HorizontalAlignment="Center"
                            Margin="0,8,0,0"
                            Command="{Binding RetryPageCommand}" />
                </StackPanel>
            </Border>
        </Panel>
    </Panel>
    <Window.Styles>
        <Style Selector="Border.content-dimmed">
            <Setter Property="Opacity" Value="0.35" />
        </Style>
        <Style Selector="Panel.overlay-panel">
            <Style.Animations>
                <Animation Duration="0:0:0.22" FillMode="Forward">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="1" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Button.nav-item">
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius"    Value="8" />
            <Setter Property="Padding"         Value="12,10" />
            <Setter Property="Cursor"          Value="Hand" />
        </Style>
        <Style Selector="Button.nav-item /template/ ContentPresenter">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.12" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.nav-item:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}" />
        </Style>
    </Window.Styles>
</Window>
