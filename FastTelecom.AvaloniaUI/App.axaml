<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:FastTelecom.AvaloniaUI"
             x:Class="FastTelecom.AvaloniaUI.App"
             RequestedThemeVariant="Light">
    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>
    <Application.Resources>
        <FontFamily x:Key="InterFont">avares://Avalonia.Fonts.Inter/Assets#Inter</FontFamily>
        <Color x:Key="AccentColor">#2563EB</Color>
        <Color x:Key="AccentHoverColor">#1D4ED8</Color>
        <Color x:Key="SurfaceColor">#F8FAFC</Color>
        <Color x:Key="CardColor">#FFFFFF</Color>
        <Color x:Key="BorderColor">#E2E8F0</Color>
        <Color x:Key="TextPrimaryColor">#0F172A</Color>
        <Color x:Key="TextSecondaryColor">#64748B</Color>
        <Color x:Key="TextMutedColor">#94A3B8</Color>
        <Color x:Key="SuccessColor">#16A34A</Color>
        <Color x:Key="DangerColor">#DC2626</Color>
        <Color x:Key="SidebarColor">#0F172A</Color>
        <Color x:Key="SidebarTextColor">#CBD5E1</Color>
        <Color x:Key="SidebarActiveColor">#1E293B</Color>
        <SolidColorBrush x:Key="AccentBrush"        Color="{StaticResource AccentColor}" />
        <SolidColorBrush x:Key="AccentHoverBrush"   Color="{StaticResource AccentHoverColor}" />
        <SolidColorBrush x:Key="SurfaceBrush"       Color="{StaticResource SurfaceColor}" />
        <SolidColorBrush x:Key="CardBrush"          Color="{StaticResource CardColor}" />
        <SolidColorBrush x:Key="BorderBrush"        Color="{StaticResource BorderColor}" />
        <SolidColorBrush x:Key="TextPrimaryBrush"   Color="{StaticResource TextPrimaryColor}" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
        <SolidColorBrush x:Key="TextMutedBrush"     Color="{StaticResource TextMutedColor}" />
        <SolidColorBrush x:Key="SuccessBrush"       Color="{StaticResource SuccessColor}" />
        <SolidColorBrush x:Key="DangerBrush"        Color="{StaticResource DangerColor}" />
        <SolidColorBrush x:Key="SidebarBrush"       Color="{StaticResource SidebarColor}" />
        <SolidColorBrush x:Key="SidebarTextBrush"   Color="{StaticResource SidebarTextColor}" />
        <SolidColorBrush x:Key="SidebarActiveBrush" Color="{StaticResource SidebarActiveColor}" />
    </Application.Resources>
    <Application.Styles>
        <FluentTheme />

        <Style Selector="Window">
            <Setter Property="FontFamily" Value="{StaticResource InterFont}" />
            <Setter Property="FontSize"   Value="14" />
        </Style>

        <Style Selector="Border.overlay-card">
            <Setter Property="Background"   Value="{StaticResource CardBrush}" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding"      Value="44,36" />
            <Setter Property="BoxShadow"    Value="0 12 60 0 #50000000" />
            <Setter Property="MinWidth"     Value="300" />
        </Style>
        <Style Selector="Button.overlay-retry">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding"      Value="28,10" />
            <Setter Property="FontWeight"   Value="Medium" />
            <Setter Property="Cursor"       Value="Hand" />
        </Style>
        <Style Selector="Button.overlay-retry /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Button.overlay-retry:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource AccentHoverBrush}" />
        </Style>
        <Style Selector="Ellipse.dot-1">
            <Setter Property="Fill" Value="{StaticResource AccentBrush}" />
            <Style.Animations>
                <Animation Duration="0:0:1.4" IterationCount="Infinite">
                    <KeyFrame Cue="0%">   <Setter Property="Opacity" Value="0.2" /></KeyFrame>
                    <KeyFrame Cue="20%">  <Setter Property="Opacity" Value="1.0" /></KeyFrame>
                    <KeyFrame Cue="60%">  <Setter Property="Opacity" Value="0.2" /></KeyFrame>
                    <KeyFrame Cue="100%"> <Setter Property="Opacity" Value="0.2" /></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Ellipse.dot-2">
            <Setter Property="Fill" Value="{StaticResource AccentBrush}" />
            <Style.Animations>
                <Animation Duration="0:0:1.4" IterationCount="Infinite" Delay="0:0:0.22">
                    <KeyFrame Cue="0%">   <Setter Property="Opacity" Value="0.2" /></KeyFrame>
                    <KeyFrame Cue="20%">  <Setter Property="Opacity" Value="1.0" /></KeyFrame>
                    <KeyFrame Cue="60%">  <Setter Property="Opacity" Value="0.2" /></KeyFrame>
                    <KeyFrame Cue="100%"> <Setter Property="Opacity" Value="0.2" /></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Ellipse.dot-3">
            <Setter Property="Fill" Value="{StaticResource AccentBrush}" />
            <Style.Animations>
                <Animation Duration="0:0:1.4" IterationCount="Infinite" Delay="0:0:0.44">
                    <KeyFrame Cue="0%">   <Setter Property="Opacity" Value="0.2" /></KeyFrame>
                    <KeyFrame Cue="20%">  <Setter Property="Opacity" Value="1.0" /></KeyFrame>
                    <KeyFrame Cue="60%">  <Setter Property="Opacity" Value="0.2" /></KeyFrame>
                    <KeyFrame Cue="100%"> <Setter Property="Opacity" Value="0.2" /></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </Application.Styles>
</Application>
